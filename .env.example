# --- WhatsApp Business API (optional) ---
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- Redis for queues (required for production) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Security ---
ENCRYPTION_KEY=your-32-character-encryption-key-here
BASE_URL=http://localhost:3000

# --- API server (artifacts/api-server) & shared lib/db ---
# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@host:5432/database

# Session cookie signing (change in production)
SESSION_SECRET=change-this-session-secret

# Production: NODE_ENV=production (secure cookies, trust proxy)
# NODE_ENV=production

# Comma-separated browser origins (required if frontend and API are on different sites)
# CORS_ORIGIN=https://skillfit.example.com,https://www.skillfit.example.com

# Questions per interview (3–12, default 5)
# INTERVIEW_QUESTION_COUNT=5

# Admin: prefer database users — run: pnpm --filter @workspace/api-server run seed:admin
# SEED_ADMIN_USER=admin
# SEED_ADMIN_PASSWORD=change-this-password
# SEED_ADMIN_ROLE=super_admin

# Fallback env-only login if no row in admin_users (disable in production by seeding admins)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin123
# ADMIN_ROLE=officer

# --- Gemini (pick one setup) ---
# Replit AI integration:
# AI_INTEGRATIONS_GEMINI_BASE_URL=
# AI_INTEGRATIONS_GEMINI_API_KEY=

# Local / Google AI Studio — use one API key:
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash-lite

# --- Optional: Groq Whisper for /api/transcribe (better dialect ASR) ---
GROQ_API_KEY=

# --- Frontend (artifacts/skillfit) — optional video storage ---
# VITE_API_BASE_URL=http://localhost:3000
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
# Optional: load face-api.js TinyFaceDetector (CDN models) in addition to heuristic face check
# VITE_USE_FACE_API=true

# Ports
# PORT=3000
# VITE_DEV_PORT=5173
